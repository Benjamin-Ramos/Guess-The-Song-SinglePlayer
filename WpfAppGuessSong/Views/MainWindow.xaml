<Window x:Class="WpfAppGuessSong.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Song Guesser Challenge" Height="850" Width="1000"
        Icon="pack://application:,,,/Assets/favicon.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/ExplosionesDeEstilos.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" 
                Margin="20" Padding="15,8" CornerRadius="12" 
                Background="{StaticResource PanelBrush}" 
                BorderBrush="{StaticResource ButtonPrimaryBrush}" BorderThickness="2" Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SCORE: " Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Aciertos}" Foreground="{StaticResource ButtonPrimaryBrush}" 
                           FontSize="28" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="MyScrollViewer" VerticalScrollBarVisibility="Auto" Focusable="False">
            <StackPanel Margin="30,50,30,30" ScrollViewer.CanContentScroll="True">

                <TextBlock Text="ADIVINA LA FOKIN CANCIÓN" 
                           FontSize="42" FontWeight="ExtraBold" 
                           Foreground="{StaticResource ButtonPrimaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="25" Color="#00E676" Opacity="0.6" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="15" Margin="0,0,0,25" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Artista:" VerticalAlignment="Center" Margin="5,0,15,0" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="16"/>
                        <TextBox Grid.Column="1" Text="{Binding ArtistaABuscar, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="18" Padding="12,10" Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#444"/>
                        <Button Grid.Column="2" Content="BUSCAR" Click="BtnBuscar_Click" 
                                Style="{StaticResource GameButtonStyle}" Margin="15,0,0,0" Width="140" Height="45"/>
                    </Grid>
                </Border>

                <StackPanel IsEnabled="{Binding JuegoActivo}">
                    <Border CornerRadius="12" Margin="0,0,0,25" Padding="20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FueCorrecto}" Value="True">
                                        <Setter Property="Background" Value="#1B5E20"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Mensaje}" FontSize="24" Foreground="White" HorizontalAlignment="Center" FontWeight="ExtraBold">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>

                    <Border Width="280" Height="280" CornerRadius="25" Background="Black" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Color="#000" Opacity="0.9"/>
                        </Border.Effect>

                        <Grid Background="#1A1A1A">
                            <Image Source="{Binding CancionActual.artworkUrl100}" 
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="UniformToFill"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                            <Image Source="{Binding FotoArtista}" 
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="UniformToFill"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MostrarPortadaReal}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FotoArtista}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="25">
                        <Button Content="▶ ESCUCHAR" Click="BtnReproducir_Click" 
                                Style="{StaticResource GameButtonStyle}"
                                Width="200" Height="60" FontSize="16"/>
                        <Button Content="■ STOP" Click="BtnParar_Click" 
                                Style="{StaticResource GameButtonStyle}"
                                Background="{StaticResource ButtonSecondaryBrush}"
                                Width="120" Height="60" Margin="20,0,0,0" FontSize="16"/>
                        <Button Content="➔ SKIP" Click="BtnSkip_Click" 
                                Style="{StaticResource GameButtonStyle}" 
                                Background="{StaticResource SkipBrush}"
                                Width="120" Height="60" Margin="20,0,0,0" FontSize="16"/>
                    </StackPanel>

                    <ComboBox x:Name="ComboRespuestas"
                              Style="{StaticResource GameComboBoxStyle}"
                              ItemsSource="{Binding CancionesRestantes}" 
                              DisplayMemberPath="trackName"
                              Width="600" Height="55"
                              HorizontalAlignment="Center" FontSize="18"
                              IsEditable="True"
                              IsTextSearchEnabled="False" 
                              StaysOpenOnEdit="True"
                              KeyUp="ComboRespuestas_KeyUp">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="15,10"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <Button Content="¡CONFIRMAR RESPUESTA!" Click="BtnComprobar_Click" 
                            Style="{StaticResource GameButtonStyle}" Width="350" Height="70" 
                            IsDefault="True" Margin="25" FontSize="22"/>
                </StackPanel>

               
                <TextBlock Text="HISTORIAL DE PARTIDA" HorizontalAlignment="Center" Foreground="#555" Margin="0,30,0,10" FontWeight="Bold" FontSize="14"/>

                <DataGrid ItemsSource="{Binding ListaCanciones}" AutoGenerateColumns="False" Height="200" IsReadOnly="True" 
                          Background="#1A1A1A" Foreground="{StaticResource TextBrush}" BorderThickness="1" BorderBrush="#333"
                          RowBackground="#1E1E1E" AlternatingRowBackground="#252525" GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Ok" Binding="{Binding FueAdivinada}" Width="50"/>
                        <DataGridTextColumn Header="Título" Binding="{Binding trackName}" Width="*"/>
                        <DataGridTextColumn Header="Artista" Binding="{Binding artistName}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
               
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>